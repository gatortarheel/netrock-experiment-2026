{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning"
    }
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Database=test_db;Username=test;Password=test"
  },
  "Caching": {
    "Enabled": false,
    "Redis": {
      "Enabled": false
    }
  },
  "JobScheduling": {
    "Enabled": false
  },
  "Email": {
    "FrontendBaseUrl": "https://test.example.com"
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 10000,
      "Window": "00:00:10"
    },
    "Registration": {
      "PermitLimit": 10000,
      "Window": "00:00:10"
    },
    "Auth": {
      "PermitLimit": 10000,
      "Window": "00:00:10"
    },
    "Sensitive": {
      "PermitLimit": 10000,
      "Window": "00:00:10"
    },
    "AdminMutations": {
      "PermitLimit": 10000,
      "Window": "00:00:10"
    }
  },
  "Captcha": {
    "SecretKey": "1x0000000000000000000000000000000AA"
  },
  "Hosting": {
    "ForceHttps": false
  },
  "Cors": {
    "AllowAllOrigins": false,
    "AllowedOrigins": [
      "https://test.example.com"
    ],
    "PolicyName": "DefaultCorsPolicy"
  },
  "FileStorage": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "testaccess",
    "SecretKey": "testsecret",
    "BucketName": "test-files",
    "UseSSL": false
  }
}
